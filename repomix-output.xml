                <p class="text-sm text-muted-foreground leading-relaxed">Tiempo, costo y cómo lo voy a hacer. Clarito desde el principio.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="step-number" style="width: 2rem; height: 2rem; font-size: 0.8125rem;">3</span>
              <div>
                <p class="font-body font-semibold text-foreground text-sm mb-1">Lo construyo y te lo entrego</p>
                <p class="text-sm text-muted-foreground leading-relaxed">Te explico cómo usarlo y te quedas con algo que sí sirve.</p>
              </div>
            </div>
          </div>

          <div class="mt-6 pt-5 border-t border-border flex items-center gap-3 text-sm text-muted-foreground">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <span>Entrevista inicial sin costo</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</file>

<file path="src/layouts/Layout.astro">
---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Xolventa | Software, Webs y Automatización con IA — Cd. Victoria',
  description = 'Ayudo a negocios locales de Cd. Victoria a automatizar procesos, crear sistemas de venta e inventario, y dar a conocer sus servicios con páginas web profesionales. Pago único o mensual según el proyecto.'
} = Astro.props;

const domain = 'https://xolventa.vercel.app';
const ogImage = `${domain}/og-image.webp`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/robot.png" />
    <link rel="apple-touch-icon" href="/robot.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="software Cd. Victoria, sistemas de venta, inventario, páginas web, automatización IA, desarrollo web Tamaulipas, punto de venta, negocio local" />
    <link rel="canonical" href={domain} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={domain} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Xolventa",
      "description": description,
      "url": domain,
      "image": ogImage,
      "telephone": "+528342550555",
      "email": "",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad Victoria",
        "addressRegion": "Tamaulipas",
        "addressCountry": "MX"
      },
      "areaServed": "Ciudad Victoria, Tamaulipas",
      "priceRange": "$$",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+528342550555",
        "contactType": "sales",
        "availableLanguage": ["Spanish"]
      },
      "sameAs": ["https://wa.me/528342550555"]
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <Analytics />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

        const year = new Date().getFullYear();
        document.querySelectorAll('.current-year').forEach(el => { el.textContent = year });
      });
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-body antialiased">
    <slot />
  </body>
</html>
</file>

